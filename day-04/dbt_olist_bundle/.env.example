# Copy to .env and fill in, then load it (see README). .env is gitignored — never commit.
#
# These four power LOCAL dbt runs (`uv run dbt ... --target local`). They are the SAME names the
# profile reads in the deployed job — but there the values come from Databricks, not this file:
#   - DBT_HOST + DBT_ACCESS_TOKEN : INJECTED by Databricks when dbt runs as a job task
#   - DBT_HTTP_PATH + DBT_CATALOG : supplied by the bundle via the job cluster's spark_env_vars
# So you only ever fill these in for laptop runs.

DBT_HOST=adb-1234567890.11.azuredatabricks.net    # workspace host (bare, no https://)
DBT_ACCESS_TOKEN=dapiXXXXXXXX                      # your PAT (local only; never commit)
DBT_HTTP_PATH=/sql/1.0/warehouses/abc123          # SQL Warehouse > Connection details
DBT_CATALOG=training_sukru_hansahin               # your personal catalog (training_<name>)

# dev / prod need NOTHING here: CI deploys them via GitHub OIDC (no stored secret), and the
# dbt job authenticates with the injected DBT_HOST / DBT_ACCESS_TOKEN. See .github/workflows/.
