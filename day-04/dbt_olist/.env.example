# Copy to .env and fill in, then load it (see README). .env is gitignored — never commit.

# --- local target (training) : the only block trainees need ---
DATABRICKS_HOST=adb-1234567890.11.azuredatabricks.net   # bare hostname, no https://
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abc123         # SQL Warehouse > Connection details
DATABRICKS_TOKEN=dapiXXXXXXXX                           # PAT (local/dev only)
DBT_USER=sukru_hansahin                                 # informational; set your personal catalog as training_<name>

# --- dev / prod targets (CI uses a service principal; set these in the secret store, not here) ---
# DATABRICKS_DEV_HOST=adb-dev.azuredatabricks.net
# DATABRICKS_DEV_HTTP_PATH=/sql/1.0/warehouses/devxxxx
